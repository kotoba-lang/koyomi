{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc → portable to JVM / SCI / ClojureScript / GraalVM). Same runtime
 ;; kekkai/tayori ride on; a schedule-sharing control plane is just another
 ;; sealed-intelligence ⊣ independent-governor StateGraph.
 :deps {io.github.kotoba-lang/langgraph
        {:git/url "https://github.com/kotoba-lang/langgraph.git"
         :sha "5b4e5e70837b849b14b6a5800894e3be202ad5fa"}
        ;; canonical did:key + IPNS-name derivation (ADR-2607050100) — same
        ;; copy kekkai/tayori's CACAO issuance uses.
        io.github.kotoba-lang/ed25519
        {:sha "fdcefb9f1b83461fee54d04b63e374fa301ee847"}
        io.github.kotoba-lang/ipns
        {:sha "f2563eb1cb010c96f6dec1dfbd468fac93367498"}
        ;; the calendar.model event EDN koyomi holds verbatim as :draft
        ;; content — koyomi does NOT reimplement it (ADR-2607062010).
        io.github.kotoba-lang/calendar
        {:local/root "../calendar"}
        ;; koyomi.distribute's REAL Resend ScheduleTarget builds its request
        ;; via kotoba-lang/mailer (which itself depends on kotoba-lang/mail
        ;; for mail.message/mail.draft/mail.receipt) rather than reimplementing
        ;; Resend request-building — same layering cloud-itonami.mail rides on.
        io.github.kotoba-lang/mailer
        {:local/root "../mailer"}
        ;; koyomi.distribute owns the network call + JSON envelope itself
        ;; (mirrors cloud_itonami.mail's charter: "only this namespace touches
        ;; the network ... mail.*/mailer.* stay pure") — same lightweight
        ;; org.clojure/data.json choice cloud-itonami's deps.edn lists first.
        org.clojure/data.json
        {:mvn/version "2.5.1"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain {:local/root "../langchain"}}}
  ;; clojure -M:dev:run  → drive a schedule-share through one ScheduleActor
  :run {:main-opts ["-m" "koyomi.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}}}
